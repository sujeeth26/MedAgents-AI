# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to GitHub!

# ============================================
# PINECONE (Vector Database)
# ============================================
# Get your API key from: https://app.pinecone.io/
PINECONE_API_KEY=pcsk_your_pinecone_api_key_here
PINECONE_INDEX_NAME=medagentica-demo-384

# ============================================
# LLM PROVIDER (Choose one)
# ============================================

# Option 1: Groq (Free, Fast)
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Option 2: OpenRouter (Multiple Models)
# Get your API key from: https://openrouter.ai/
OPENROUTER_API_KEY=sk_your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1:free

# Option 3: OpenAI (Paid, High Quality)
# Get your API key from: https://platform.openai.com/
OPENAI_API_KEY=sk_your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4o-mini

# ============================================
# OPTIONAL SERVICES
# ============================================

# Tavily (Web Search)
TAVILY_API_KEY=your_tavily_key_here

# ElevenLabs (Text-to-Speech)
ELEVEN_LABS_API_KEY=your_elevenlabs_key_here

# ============================================
# CONFIGURATION
# ============================================

PDF_DIRECTORY=./data/raw
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_STORE_PROVIDER=pinecone
EMBEDDING_PROVIDER=huggingface
